# Supabase — public (safe to expose to the browser, RLS-bound)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase — SERVER ONLY. Bypasses RLS. NEVER prefix with NEXT_PUBLIC_ and never
# import into a "use client" module. Used by the admin client + seed scripts.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Supabase CLI (local / CI only — do not ship to the app runtime)
SUPABASE_PROJECT_REF=your-project-ref
SUPABASE_DB_PASSWORD=your-db-password
