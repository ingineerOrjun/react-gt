# Supabase — public (safe to expose to the browser, RLS-bound)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase — SERVER ONLY. Bypasses RLS. NEVER prefix with NEXT_PUBLIC_ and never
# import into a "use client" module. Used by the admin client + seed scripts.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Supabase CLI (local / CI only — do not ship to the app runtime)
SUPABASE_PROJECT_REF=your-project-ref
SUPABASE_DB_PASSWORD=your-db-password

# Monitoring (optional — features stay inert until set)
# Google Analytics 4 measurement id
NEXT_PUBLIC_GA_ID=
# Sentry DSN (public) + build-time source-map upload (CI only)
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# Cloudflare Turnstile — contact-form bot protection.
# Site key is public (browser widget); secret key is server-only (verification).
# Feature stays inert until both are set.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Upstash Redis — contact-form rate limiting (5 req / 10 min / IP).
# From the Upstash console or the Vercel + Upstash integration. Inert until set.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Verification/setup admin (local scripts only)
ADMIN_EMAIL=
ADMIN_PASSWORD=
